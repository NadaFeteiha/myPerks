# ═══════════════════════════════════════════════════════
# MyPerks — Environment Variables
# Copy this to .env and fill in your values.
# ═══════════════════════════════════════════════════════

# ───── Clerk Auth (shared by frontend & backend) ─────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Clerk JWKS URL — used by FastAPI to verify session tokens
# Find it in Clerk Dashboard → API Keys → Advanced
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# ───── Frontend (Next.js) ─────
# URL of the FastAPI backend (localhost in dev, Render URL in prod)
NEXT_PUBLIC_API_URL=http://localhost:8000

# UploadThing — for HR PDF uploads
# Create a free app at uploadthing.com
UPLOADTHING_TOKEN=...
NEXT_PUBLIC_UPLOADTHING_APP_ID=...

# Sentry (optional — error monitoring)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ───── Backend (FastAPI) ─────
# PostgreSQL with pgvector extension
# Local: postgresql+asyncpg://postgres:postgres@localhost:5432/myperks_development
# Neon:  postgresql+asyncpg://<user>:<pass>@<host>/neondb?ssl=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/myperks_development

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...        # used for embeddings (text-embedding-3-small)

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
